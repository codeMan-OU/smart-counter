# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments and local Python tooling
.venv/
venv/
env/
ENV/
pip-wheel-metadata/

# Build and packaging outputs
build/
dist/
*.egg-info/
*.spec

# Runtime logs and generated counting records
logs/
*.log

# Local settings generated by editors and operating systems
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/

# Local environment files
.env
.env.*

# Temporary files
*.tmp
*.temp
~$*

# Project assets currently kept in Git because they are small enough:
# - PTmodel/*.pt
# - video/*.mp4
# - voice-wav/*.wav
#
# If future models or videos become too large for GitHub, uncomment these
# lines and provide those files through Git LFS or an external download:
